require "base64"
require "tmpdir"

default_platform(:ios)

APP_ID    = "com.lightwave.zeus"
WIDGET_ID = "com.lightwave.zeus.widgets"
PROJECT   = "Zeus.xcodeproj"
SCHEME    = "Zeus"

platform :ios do
  desc "Build and upload a TestFlight build (automatic signing via ASC API key)"
  lane :beta do
    # Creates a temporary CI keychain when running on CI (no-op locally).
    setup_ci

    # Accept ASC_KEY_CONTENT as either the raw .p8 (PEM) text or base64 of it.
    key_id    = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")
    raw_key   = ENV.fetch("ASC_KEY_CONTENT").strip
    key_pem   = raw_key.include?("BEGIN") ? raw_key : Base64.decode64(raw_key)

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_pem,
      is_key_content_base64: false
    )

    # xcodebuild needs the API key on disk to authenticate cloud signing
    # (-allowProvisioningUpdates), so it can create the distribution cert +
    # profiles itself with no Apple ID logged in on the runner.
    key_path = File.join(Dir.tmpdir, "AuthKey_#{key_id}.p8")
    File.write(key_path, key_pem)
    auth_xcargs = "-allowProvisioningUpdates " \
                  "-authenticationKeyPath #{key_path} " \
                  "-authenticationKeyID #{key_id} " \
                  "-authenticationKeyIssuerID #{issuer_id}"

    # Generate the Xcode project from project.yml (kept out of git).
    sh("cd .. && xcodegen generate")

    # Use Xcode automatic signing; Apple manages the cert + profiles via the API
    # key during -allowProvisioningUpdates, so no certs repo / match is needed.
    team_id = ENV.fetch("TEAM_ID")
    ["Zeus", "ZeusWidgets"].each do |target|
      update_code_signing_settings(
        path: PROJECT,
        use_automatic_signing: true,
        team_id: team_id,
        targets: [target]
      )
    end

    # Build number = last TestFlight build + 1 (falls back to the CI run number).
    latest = begin
      latest_testflight_build_number(api_key: api_key, app_identifier: APP_ID, initial_build_number: 0)
    rescue StandardError
      (ENV["GITHUB_RUN_NUMBER"] || "0").to_i
    end
    increment_build_number(xcodeproj: PROJECT, build_number: latest + 1)

    build_app(
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      xcargs: auth_xcargs,
      export_options: {
        signingStyle: "automatic",
        teamID: team_id
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
