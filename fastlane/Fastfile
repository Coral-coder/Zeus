require "base64"

default_platform(:ios)

APP_ID    = "com.lightwave.zeus"
WIDGET_ID = "com.lightwave.zeus.widgets"
PROJECT   = "Zeus.xcodeproj"
SCHEME    = "Zeus"

platform :ios do
  desc "Build and upload a TestFlight build (manual signing via ASC API key)"
  lane :beta do
    # Creates a temporary CI keychain when running on CI (no-op locally).
    setup_ci

    # Accept ASC_KEY_CONTENT as either the raw .p8 (PEM) text or base64 of it.
    raw_key = ENV.fetch("ASC_KEY_CONTENT").strip
    key_pem = raw_key.include?("BEGIN") ? raw_key : Base64.decode64(raw_key)
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: key_pem,
      is_key_content_base64: false
    )
    team_id = ENV.fetch("TEAM_ID")

    # Generate the Xcode project from project.yml (kept out of git).
    sh("cd .. && xcodegen generate")

    # CI runners have no Apple ID, so automatic signing can't resolve the team.
    # Instead, use the API key to create/download a distribution certificate and
    # App Store provisioning profiles directly, then sign manually against them.
    get_certificates(api_key: api_key, generate_apple_certs: true)

    get_provisioning_profile(api_key: api_key, app_identifier: APP_ID)
    name_app = lane_context[SharedValues::SIGH_NAME]

    get_provisioning_profile(api_key: api_key, app_identifier: WIDGET_ID)
    name_widget = lane_context[SharedValues::SIGH_NAME]

    [["Zeus", APP_ID, name_app], ["ZeusWidgets", WIDGET_ID, name_widget]].each do |target, bundle_id, profile|
      update_code_signing_settings(
        path: PROJECT,
        use_automatic_signing: false,
        team_id: team_id,
        targets: [target],
        bundle_identifier: bundle_id,
        code_sign_identity: "Apple Distribution",
        profile_name: profile
      )
    end

    # Build number = last TestFlight build + 1 (falls back to the CI run number).
    latest = begin
      latest_testflight_build_number(api_key: api_key, app_identifier: APP_ID, initial_build_number: 0)
    rescue StandardError
      (ENV["GITHUB_RUN_NUMBER"] || "0").to_i
    end
    increment_build_number(xcodeproj: PROJECT, build_number: latest + 1)

    build_app(
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          APP_ID => name_app,
          WIDGET_ID => name_widget
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
