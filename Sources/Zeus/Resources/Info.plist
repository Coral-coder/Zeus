<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleDisplayName</key>
    <string>Zeus Remote</string>
    <key>CFBundleName</key>
    <string>Zeus</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.lightwave.zeus.auth</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>msauth.com.gm.mychevrolet</string>
                <string>zeus</string>
            </array>
        </dict>
    </array>
    <!-- Sideloader: allow the app's own loopback HTTPS calls (127.0.0.1 /
         localhost) to bypass ATS. The OTA fetch is done by installd (a system
         daemon not bound by this key); this only covers any in-app localhost
         request. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <!-- Sideloader: let an .ipa opened from Files / Share / Safari downloads be
         handed to Zeus (routed via onOpenURL to the hidden Sideload panel). -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>iOS App Archive</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.apple.itunes.ipa</string>
            </array>
        </dict>
    </array>
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.apple.itunes.ipa</string>
            <key>UTTypeDescription</key>
            <string>iOS App Archive</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.zip-archive</string>
                <string>public.data</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>ipa</string>
                </array>
            </dict>
        </dict>
    </array>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Zeus uses your location to find nearby chargers and show your car on the map.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Zeus learns when you typically leave home or work so it can pre-start your Bolt before you go.</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Zeus connects to your OBD-II adapter to read live vehicle data while driving.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>Zeus uses Face ID to confirm sensitive commands like unlocking and starting your car.</string>
    <key>NSSiriUsageDescription</key>
    <string>Zeus lets you start, stop, lock and check your Bolt with Siri.</string>
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>processing</string>
        <string>location</string>
        <string>bluetooth-central</string>
        <!-- Sideloader: silent-audio keep-alive so the local OTA server keeps
             running while the user is in Safari/Settings doing trust/enroll and
             while installd fetches the build. -->
        <string>audio</string>
    </array>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.lightwave.zeus.autostart</string>
    </array>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>CPTemplateApplicationSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>ZeusCarPlay</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>
</dict>
</plist>
